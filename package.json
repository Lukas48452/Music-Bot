{
    "name": "music-disc",
    "version": "4.1.3",
    "description": "Discord Music Bot",
    "main": "./src/index.ts",
    "type": "module",
    "scripts": {
        "start": "npm run build && node ./dist/src/index.js",
        "start:server": "npm run build:server && node ./dist/src/index.js",
        "build": "npm run build:dashboard && npm run build:server",
        "build:server": "tsc",
        "build:dashboard": "cd dashboard && npm run generate",
        "install:dashboard": "cd dashboard && npm install",
        "dev": "tsc --noEmit --incremental false && tsx ./src/index.ts",
        "lint": "eslint . --color"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/hmes98318/Music-Disc.git"
    },
    "author": "hmes98318",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/hmes98318/Music-Disc/issues"
    },
    "homepage": "https://github.com/hmes98318/Music-Disc#readme",
    "overrides": {
        "brace-expansion": "^5.0.6",
        "qs": "^6.15.2",
        "ws": "^8.21.0"
    },
    "dependencies": {
        "bcryptjs": "^3.0.3",
        "better-sqlite3": "^12.10.0",
        "cookie": "^1.1.1",
        "discord.js": "~14.26.4",
        "dotenv": "^17.4.2",
        "express": "^5.2.1",
        "i18next": "^26.2.0",
        "i18next-fs-backend": "^2.6.6",
        "lavashark": "^2.3.2",
        "undici": "^8.3.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/better-sqlite3": "^7.6.13",
        "@types/express": "^5.0.6",
        "@types/node": "^25.9.1",
        "eslint": "^10.4.0",
        "globals": "^17.6.0",
        "tsx": "^4.22.3",
        "typescript": "~6.0.3",
        "typescript-eslint": "^8.59.4"
    },
    "engines": {
        "node": ">=22.22.3"
    }
}
